# ── 应用 ────────────────────────────────────────────────────
APP_NAME=colony
APP_ENV=development
DEBUG=true

# ── 数据库（必须使用 asyncpg 驱动） ──────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/colony
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

# ── 安全 ────────────────────────────────────────────────────
# 生产环境必须替换为 ≥32 字节随机字符串
# 生成：python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_AT_LEAST_32_CHARS_LONG
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Fernet 加密密钥（用于加密 Provider API Key）
# 生成：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── S3 / MinIO ──────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=colony
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRE=900
S3_ARTIFACT_URL_EXPIRE=259200

# ── Agent 默认主模型（格式 `provider_name/model_id`；裸 model_id 若跨 provider 重名会报错消歧） ──
# DEFAULT_AGENT_MODEL_ID=e2e-gemini/gemini-3.1-flash-lite-preview
# DEFAULT_SUPERVISOR_MODEL_ID=nebula/claude-opus-4-6   # 留空则同 DEFAULT_AGENT_MODEL_ID

# ── LLM 调用韧性 & 超时（全部可选，下面是默认值） ──────────
# LLM_FIRST_TOKEN_TIMEOUT_S=30     # 首 token 预算（秒）
# LLM_RETRY_MAX=3                  # LLM 调用重试次数（不含初始那次）
# WORKER_INVOKE_TIMEOUT_SEC=600    # 单个 Worker Agent ainvoke 超时（秒）
# TURN_TIMEOUT_SEC=1800            # 单轮 chat turn 总超时（秒；必须 > WORKER_INVOKE_TIMEOUT_SEC）

# ── 上下文自动压缩阈值（新建 Project 的默认 context_compression_threshold；token 数） ──
# 估算的是**整个组装 context**：supervisor 系统提示 + memory_md + workspace 快照 + 未压缩对话
# 默认 300000 ≈ 30 万 token，覆盖 1M 窗口的 1/3 安全边界
# DEFAULT_CONTEXT_COMPRESSION_THRESHOLD=300000

# ── 初始管理员账号（首次启动时创建） ────────────────────────
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@colony.com
INIT_ADMIN_PASSWORD=admin123

# ── ClawHub（M6 远程 Skill 仓库） ───────────────────────────
# 鉴权 token；可空走匿名读（速率限制更低）；写/账户操作必须有 token
CLAWHUB_TOKEN=
CLAWHUB_BASE_URL=https://clawhub.ai
# 远程 skill 安装目录（被 .gitignore 排除）
CLAWHUB_INSTALL_DIR=runtime/skills
